{
  "$schema": "https://opencode.ai/config.json",
   "plugin": ["@mohak34/opencode-notifier@latest"],
   "compaction": {
    "auto": false,
    "prune": true,
    "reserved": 0
   },
   "permission": {
    "bash": {
      "*": "ask",
      "brew *": "deny",
      "git push *": "deny",
      "dotnet build *": "allow",
      "dotnet test *": "allow",
      "dotnet restore *": "allow",
      "rg *": "allow",
      "echo *": "allow",
      "grep *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "git status *": "allow",
      "git diff *":"allow"
    }
   }
}