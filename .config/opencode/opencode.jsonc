{
  "$schema": "https://opencode.ai/config.json",
   "plugin": ["@mohak34/opencode-notifier@latest"],
   "permission": {
    "bash": {
      "*": "ask",
      "brew *": "deny",
      "git push *": "deny",
      "dotnet build *": "allow",
      "dotnet test *": "allow",
      "dotnet restore *": "allow",
    }
   }
}